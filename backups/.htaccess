# Carpeta de backups: BLOQUEAR todo acceso público
# Los archivos solo se sirven a través de admin/backups.php?descargar=N
# que valida que el usuario sea administrador autenticado.

Require all denied

# Sin listado de directorio
Options -Indexes

# Por si Require all denied no funciona en alguna versión vieja de Apache
<FilesMatch ".*">
    Order deny,allow
    Deny from all
</FilesMatch>
